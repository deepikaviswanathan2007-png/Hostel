PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=hostel_mgmt
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Optional rate-limit tuning
RATE_LIMIT_GLOBAL_WINDOW_MS=300000
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_AUTH_WINDOW_MS=300000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_WRITE_WINDOW_MS=300000
RATE_LIMIT_WRITE_MAX=120
 